{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexara.dev/schemas/plugin-manifest-v1.json",
  "title": "NEXARA Plugin Manifest Schema V1",
  "description": "Plugin capability declaration — declaring a capability does NOT authorize execution. Policy must grant permission separately.",
  "type": "object",
  "required": ["plugin_id", "name", "version", "capabilities"],
  "properties": {
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{2,63}$",
      "description": "Globally unique plugin identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
      "description": "SemVer 2.0.0"
    },
    "description": {
      "type": "string",
      "maxLength": 1024
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.]{1,127}$"
      },
      "description": "Capability IDs this plugin provides"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "file.read", "file.write", "network.outbound", "network.inbound",
          "process.spawn", "model.invoke", "memory.read", "memory.write",
          "evidence.create", "approval.request", "secret.read"
        ]
      },
      "description": "Permissions this plugin requires"
    },
    "network_scope": {
      "type": "array",
      "items": {"type": "string", "format": "hostname"},
      "description": "Allowed network domains"
    },
    "secret_scope": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Keychain paths this plugin may access"
    },
    "risk_level": {
      "type": "string",
      "enum": ["R0", "R1", "R2", "R3", "R4"],
      "default": "R2",
      "description": "Maximum risk level of plugin capabilities"
    },
    "signature_required": {
      "type": "boolean",
      "default": true,
      "description": "Whether the plugin must be signed"
    },
    "isolation": {
      "type": "string",
      "enum": ["process", "sandbox", "none"],
      "default": "process",
      "description": "Isolation level: process (separate process), sandbox (macOS sandbox-exec), none (in-process, dev only)"
    },
    "entry_point": {
      "type": "string",
      "description": "Module:function or command to invoke the plugin"
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Other plugin_ids this plugin depends on"
    },
    "health_check": {
      "type": "string",
      "description": "Command or endpoint to verify plugin health"
    }
  }
}
